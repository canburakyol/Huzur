<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Huzur App
    - Disables cleartext (HTTP) traffic for security
    - Enforces HTTPS for all connections
    - Prevents Man-in-the-Middle (MITM) attacks
    - Certificate pinning intentionally omitted unless actively maintained
-->
<network-security-config>
    <!-- Base configuration for all connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificates only -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- AlAdhan API - Prayer times -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.aladhan.com</domain>
    </domain-config>
    
    <!-- Firebase APIs -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">firebase.googleapis.com</domain>
        <domain includeSubdomains="true">firebasestorage.app</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <!-- Firebase uses Google Trust Services - pins managed by SDK -->
    </domain-config>
    
    <!-- RevenueCat API -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.revenuecat.com</domain>
    </domain-config>
    
    <!-- Debug configuration (REMOVE IN PRODUCTION) -->
    <!-- 
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
    -->
</network-security-config>
