<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Huzur App
    - Disables cleartext (HTTP) traffic for security
    - Enforces HTTPS for all connections
    - Prevents Man-in-the-Middle (MITM) attacks
-->
<network-security-config>
    <!-- Base configuration for all connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificates only -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Debug configuration (optional - for development only) -->
    <!-- Uncomment below during development if needed
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
    -->
</network-security-config>
