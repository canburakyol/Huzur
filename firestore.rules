rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Existing rules for Huzur App
    match /duas/{duaId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['text', 'count', 'date']);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count']);
    }
    
    match /hatims/{hatimId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['title', 'createdAt', 'createdBy', 'participants', 'parts', 'accessCode']);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'parts', 'completedParts']);
    }

    // New rules for X-Algo Viral App
    match /viral_history/{docId} {
      allow read, write: if true; // In production, this should be restricted to authenticated users
    }
    
    match /trends/{docId} {
      allow read: if true;
      allow write: if false; // Only admin/functions should write trends
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
