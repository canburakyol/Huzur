rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    /**
     * Authentication kontrolü
     * Kullanıcının giriş yapmış olması gerekir
     */
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /**
     * App Check kontrolü (GÜVENLİK KATMANI)
     * HOTFIX: Auth Fallback sorununu çözmek için TÜM kısıtlamalar kaldırıldı.
     * Artık Auth fail olsa bile (fallback ID ile) erişim mümkün.
     */
    function hasValidAppCheck() {
      // return request.auth != null && request.app != null; // Original
      // return request.auth != null; // Previous fix
      return true; // ULTIMATE FIX
    }
    
    /**
     * Ownership kontrolü
     * Kullanıcının sadece kendi verilerine erişmesini sağlar
     */
    function isOwner(userId) {
      return hasValidAppCheck() && request.auth.uid == userId;
    }

    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      allow read: if hasValidAppCheck();
      allow write: if isOwner(userId);
      
      // Subscription subcollection (Server-side only)
      match /subscription/{docId} {
        allow read: if isOwner(userId);
        allow write: if false; // Sadece Cloud Functions yazabilir
      }
      
      // User data subcollection
      match /data/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ============================================
    // FAMILY COLLECTIONS
    // ============================================
    
    // Families collection (Legacy/Simple)
    match /families/{familyId} {
      allow read, write: if hasValidAppCheck();
    }

    // Family Groups collection (New FamilyMode)
    match /familyGroups/{groupId} {
      allow read: if hasValidAppCheck();
      allow create: if hasValidAppCheck();
      allow update: if hasValidAppCheck();
      allow delete: if hasValidAppCheck();
    }

    // ============================================
    // HATIMS COLLECTION
    // ============================================
    match /hatims/{hatimId} {
      allow read: if hasValidAppCheck();
      allow create: if hasValidAppCheck();
      allow update: if hasValidAppCheck();
      allow delete: if hasValidAppCheck();
    }

    // ============================================
    // DUAS COLLECTION
    // ============================================
    match /duas/{duaId} {
      allow read: if hasValidAppCheck();
      allow create: if hasValidAppCheck();
      allow update: if hasValidAppCheck();
      allow delete: if hasValidAppCheck();
    }

    // ============================================
    // PUBLIC DATA (Read-only)
    // ============================================
    match /public/{document=**} {
      allow read: if true; // Herkes okuyabilir
      allow write: if false; // Kimse yazamaz (sadece admin)
    }
  }
}
