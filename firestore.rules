rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------
    // Helpers
    // --------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // join/read erişimi için ortak üyelik kontrolü
    function isInStringArray(fieldName) {
      return isAuthenticated()
        && (fieldName in resource.data)
        && (request.auth.uid in resource.data[fieldName]);
    }

    function isHatimMember() {
      return isAuthenticated()
        && (
          (resource.data.createdBy == request.auth.uid)
          || isInStringArray('participants')
          || isInStringArray('readers')
        );
    }

    // --------------------------------------------
    // USERS
    // --------------------------------------------
    match /users/{userId} {
      // Aile/hatim üyelerini görüntüleme için authenticated read açık
      allow read: if isAuthenticated();

      // Kullanıcı sadece kendi dokümanını yazabilir
      allow create, update, delete: if isOwner(userId);

      // Subscription: client write kapalı (Cloud Functions)
      match /subscription/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Kişisel alt veriler: sadece owner
      match /data/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --------------------------------------------
    // FAMILIES (legacy)
    // --------------------------------------------
    match /families/{familyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // --------------------------------------------
    // FAMILY GROUPS
    // --------------------------------------------
    match /familyGroups/{groupId} {
      allow read: if isAuthenticated();

      // Grup oluşturan kullanıcı createdBy olarak kendi uid'ini yazmalı
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;

      // Güncelleme: authenticated (uygulama akışında join request/members güncelleniyor)
      allow update: if isAuthenticated();

      // Silme: sadece grup sahibi
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }

    // --------------------------------------------
    // HATIMS
    // --------------------------------------------
    match /hatims/{hatimId} {
      // Listeleme, kodla katılım ve detay akışı için authenticated read
      allow read: if isAuthenticated();

      // Oluşturma: createdBy zorunlu ve auth uid ile eşleşmeli
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid;

      // Güncelleme: oluşturucu veya katılımcı/okuyucu
      // (mevcut uygulamada hem participants hem readers kullanılıyor)
      allow update: if isHatimMember();

      // Silme: yalnızca oluşturan kullanıcı
      allow delete: if isAuthenticated()
        && resource.data.createdBy == request.auth.uid;
    }

    // --------------------------------------------
    // DUAS
    // --------------------------------------------
    match /duas/{duaId} {
      allow read: if isAuthenticated();

      // Oluşturma:
      // - text zorunlu
      // - authorId varsa auth uid ile aynı olmalı
      // (legacy Community akışındaki authorId'siz yazımla da uyumlu)
      allow create: if isAuthenticated()
        && ('text' in request.resource.data)
        && (!( 'authorId' in request.resource.data )
            || request.resource.data.authorId == request.auth.uid);

      // Güncelleme: amin artırımı vb. için authenticated kullanıcıya izin
      allow update: if isAuthenticated();

      // Silme: authorId alanı varsa sadece sahibi; yoksa silme kapalı
      allow delete: if isAuthenticated()
        && ('authorId' in resource.data)
        && resource.data.authorId == request.auth.uid;
    }

    // --------------------------------------------
    // PUBLIC DATA
    // --------------------------------------------
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
