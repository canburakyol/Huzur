rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------
    // Helpers
    // --------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // common membership check for arrays (Hatim participants, etc.)
    function isInArray(fieldName, uid) {
      return fieldName in resource.data && uid in resource.data[fieldName];
    }

    function isHatimMember() {
      return isAuthenticated()
        && (
          resource.data.createdBy == request.auth.uid
          || isInArray('participants', request.auth.uid)
          || isInArray('readers', request.auth.uid)
        );
    }

    function isHatimOwner() {
      return isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    function isHatimImmutableFieldsUnchanged() {
      return (!('id' in resource.data) || request.resource.data.id == resource.data.id)
        && (!('createdBy' in resource.data) || request.resource.data.createdBy == resource.data.createdBy)
        && (!('joinCode' in resource.data) || request.resource.data.joinCode == resource.data.joinCode)
        && (!('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt)
        && (!('totalParts' in resource.data) || request.resource.data.totalParts == resource.data.totalParts)
        && (!('type' in resource.data) || request.resource.data.type == resource.data.type);
    }

    function hasOnlyHatimOwnerUpdatableKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'title',
        'name',
        'description',
        'isPrivate',
        'participants',
        'readers',
        'parts',
        'completedParts',
        'updatedAt'
      ]);
    }

    function isHatimReaderJoinUpdate() {
      return isAuthenticated()
        && ('readers' in resource.data)
        && (resource.data.readers is list)
        && (request.resource.data.readers is list)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readers'])
        && request.resource.data.readers.size() == resource.data.readers.size() + 1
        && request.resource.data.readers.hasAll(resource.data.readers)
        && request.auth.uid in request.resource.data.readers;
    }

    function isHatimMemberPartUpdate() {
      return isHatimMember()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'parts',
          'completedParts',
          'updatedAt'
        ]);
    }

    function isFamilyMember() {
      return isAuthenticated()
        && ('members' in resource.data)
        && (request.auth.uid in resource.data.members);
    }

    function isGroupMember() {
      return isAuthenticated()
        && (
          resource.data.createdBy == request.auth.uid
          || (('memberIds' in resource.data) && (request.auth.uid in resource.data.memberIds))
        );
    }

    function hasOnlyGroupUpdatableKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name',
        'members',
        'memberIds',
        'pendingMembers',
        'updatedAt'
      ]);
    }

    function isValidPendingMemberEntry(entry) {
      return entry is map
        && entry.keys().hasOnly(['profileId', 'requestedByUid', 'name', 'avatar', 'role', 'requestedAt'])
        && isValidString(entry.profileId, 1, 80)
        && entry.requestedByUid == request.auth.uid
        && isValidString(entry.name, 1, 80)
        && isValidString(entry.avatar, 1, 16)
        && isValidString(entry.role, 1, 20)
        && entry.requestedAt is string;
    }

    function isPendingJoinRequestUpdate() {
      return isAuthenticated()
        && ('pendingMembers' in resource.data)
        && (resource.data.pendingMembers is list)
        && (request.resource.data.pendingMembers is list)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingMembers', 'updatedAt'])
        && request.resource.data.pendingMembers.size() == resource.data.pendingMembers.size() + 1
        && request.resource.data.pendingMembers.hasAll(resource.data.pendingMembers)
        && isValidPendingMemberEntry(
          request.resource.data.pendingMembers[request.resource.data.pendingMembers.size() - 1]
        );
    }

    // String validation with XSS protection
    function isValidString(val, min, max) {
      return val is string 
        && val.size() >= min 
        && val.size() <= max
        && val != null
        && val != '';
    }

    // Safe string (no HTML/script tags)
    function isSafeString(val) {
      return val is string 
        && !val.lower().matches('.*<script.*>.*')
        && !val.lower().matches('.*javascript:.*')
        && !val.lower().matches('.*on[a-z]+\\s*=.*')
        && !val.matches('.*<.*>.*');
    }

    function isValidDuaAminIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aminCount'])
        && request.resource.data.aminCount is int
        && resource.data.aminCount is int
        && request.resource.data.aminCount == resource.data.aminCount + 1
        && request.resource.data.aminCount >= 0
        && request.resource.data.aminCount <= 999999;
    }

    // --------------------------------------------
    // USERS
    // --------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false; // GDPR: Managed via Cloud Functions if needed

      // Subscription status: Server-side only (Cloud Functions)
      match /subscription/status {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Private user data logs/settings
      match /data/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      // Personal growth/funnel analytics logs (proactive)
      match /growth_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.eventName is string;
      }
    }

    // --------------------------------------------
    // FAMILIES & GROUPS
    // --------------------------------------------
    match /families/{familyId} {
      allow read: if isFamilyMember();
      allow create: if isAuthenticated()
        && request.resource.data.adminId == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && isValidString(request.resource.data.name, 1, 80);
      allow update, delete: if isAuthenticated() && resource.data.adminId == request.auth.uid;
    }

    match /familyGroups/{groupId} {
      allow read: if isGroupMember();
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && isValidString(request.resource.data.name, 1, 80)
        && isValidString(request.resource.data.code, 6, 12);
      allow update: if ((resource.data.createdBy == request.auth.uid) && hasOnlyGroupUpdatableKeys())
        || isPendingJoinRequestUpdate();
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // --------------------------------------------
    // HATIMS
    // --------------------------------------------
    match /hatims/{hatimId} {
      allow read: if isHatimMember();
      allow create: if isAuthenticated() 
        && request.resource.data.createdBy == request.auth.uid
        && (
          (('title' in request.resource.data) && isValidString(request.resource.data.title, 1, 100))
          || (('name' in request.resource.data) && isValidString(request.resource.data.name, 1, 100))
        );
      allow update: if isHatimImmutableFieldsUnchanged()
        && (
          isHatimReaderJoinUpdate()
          || isHatimMemberPartUpdate()
          || (isHatimOwner() && hasOnlyHatimOwnerUpdatableKeys())
        );
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // --------------------------------------------
    // DUAS (Community) - Enhanced Security
    // --------------------------------------------
    match /duas/{duaId} {
      allow read: if isAuthenticated();
      
      // Create: Strict validation to prevent abuse
      allow create: if isAuthenticated()
        && isValidString(request.resource.data.text, 5, 1000)
        && isSafeString(request.resource.data.text)
        && (!( 'authorId' in request.resource.data ) || request.resource.data.authorId == request.auth.uid)
        && (!( 'userId' in request.resource.data ) || request.resource.data.userId == request.auth.uid);
      
      // Update: Only aminCount can be incremented (anti-abuse)
      allow update: if isAuthenticated()
        && isValidDuaAminIncrement();
      
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // --------------------------------------------
    // GROWTH & REFERRALS (Proactive)
    // --------------------------------------------
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && resource.data.inviterId == request.auth.uid;
      allow create: if isAuthenticated()
        && (!( 'inviteeId' in request.resource.data ) || request.resource.data.inviteeId == request.auth.uid)
        && (!( 'referralCode' in request.resource.data ) || isValidString(request.resource.data.referralCode, 3, 32))
        && (!( 'source' in request.resource.data ) || isValidString(request.resource.data.source, 1, 40));
      allow update, delete: if false;
    }

    // --------------------------------------------
    // PUBLIC DATA (Read Only)
    // --------------------------------------------
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
