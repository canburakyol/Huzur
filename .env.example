# Huzur App Environment Variables Template
# Bu dosyayı .env olarak kaydedin ve değerleri doldurun.
# ⚠️ UYARI: Gerçek API anahtarlarınızı bu dosyaya DEĞİL, .env dosyasına yazın!

# Firebase Configuration
# Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# RevenueCat Configuration
# RevenueCat Dashboard > Projects > API Keys
VITE_REVENUECAT_ANDROID_KEY=your_revenuecat_android_key_here
VITE_REVENUECAT_IOS_KEY=your_revenuecat_ios_key_here

# Gemini AI Configuration
# Google AI Studio > Get API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here
